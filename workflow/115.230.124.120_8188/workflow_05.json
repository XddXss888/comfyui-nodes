{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "waiIllustriousSDXL_v170.safetensors"
    },
    "_meta": {
      "title": "① 加载模型（选你有的模型）"
    }
  },
  "2": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "example.png"
    },
    "_meta": {
      "title": "② 上传你的图片"
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "masterpiece, best quality, highly detailed",
      "clip": [
        "1",
        1
      ]
    },
    "_meta": {
      "title": "③ 正向提示词（写你想要的）"
    }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "low quality, blurry, ugly, deformed, watermark, text",
      "clip": [
        "1",
        1
      ]
    },
    "_meta": {
      "title": "④ 负向提示词（写你不想要的）"
    }
  },
  "5": {
    "class_type": "VAEEncode",
    "inputs": {
      "pixels": [
        "2",
        0
      ],
      "vae": [
        "1",
        2
      ]
    },
    "_meta": {
      "title": "⑤ 图片编码"
    }
  },
  "6": {
    "class_type": "KSampler",
    "inputs": {
      "model": [
        "1",
        0
      ],
      "seed": 123456,
      "steps": 25,
      "cfg": 7.0,
      "sampler_name": "euler_ancestral",
      "scheduler": "karras",
      "positive": [
        "3",
        0
      ],
      "negative": [
        "4",
        0
      ],
      "latent_image": [
        "5",
        0
      ],
      "denoise": 0.5
    },
    "_meta": {
      "title": "⑥ 生成（denoise=0.5 可调）"
    }
  },
  "7": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": [
        "6",
        0
      ],
      "vae": [
        "1",
        2
      ]
    },
    "_meta": {
      "title": "⑦ 图片解码"
    }
  },
  "8": {
    "class_type": "SaveImage",
    "inputs": {
      "images": [
        "7",
        0
      ],
      "filename_prefix": "img2img_output"
    },
    "_meta": {
      "title": "⑧ 保存结果"
    }
  }
}